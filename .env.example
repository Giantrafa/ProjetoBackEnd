# Supabase / PostgreSQL
# Encontre esses valores em: Supabase Dashboard > Project Settings > Database > Connection string (JDBC)
DB_URL=jdbc:postgresql://db.<SEU-PROJECT-REF>.supabase.co:5432/postgres
DB_USER=postgres
DB_PASSWORD=sua-senha-supabase

# JWT
# Use um segredo longo e aleatório em produção
JWT_SECRET=troque-por-um-segredo-seguro-aqui
JWT_EXPIRATION_HOURS=8
